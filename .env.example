# ================= Lark App (updatejenkinsbot) =================
# Subscription mode: Receive events through a persistent connection (long connection / WebSocket).
LARK_EVENT_MODE=websocket
APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 'lark' for Lark international (open.larksuite.com); 'feishu' for China Feishu.
LARK_DOMAIN=lark
PORT=5000

# Leave blank to auto-resolve from Lark at startup.
BOT_OPEN_ID=

# ================= Jenkins login =================
JENKINS_USERNAME=your-jenkins-user
JENKINS_PASSWORD=your-jenkins-password

# ================= VPN creation =================
createvpnid=your-vpn-user
createvpnpass=your-vpn-password

# ================= Playwright / warm browser pool =================
JENKINSUPDATE_BOT_HEADLESS=1
JU_WARM_POOL=1
JU_WARM_ALLOW_COLD_FALLBACK=0
JU_WARM_PREWARM_ON_STARTUP=1
JENKINS_WARM_STARTUP_WAIT_SEC=120
JENKINS_WARM_STARTUP_BLOCK=1
VPN_WARM_BROWSER=1
VPN_WARM_PREWARM_ON_STARTUP=1
VPN_WARM_ALLOW_COLD_FALLBACK=0

# ================= Self-deploy (git pull origin main + restart service) =================
UPDATEJENKINS_SERVICE=updatejenkins
# Comma-separated Lark open_ids allowed to trigger a deploy. Empty = anyone who can @mention.
DEPLOY_ALLOWED_OPEN_IDS=

# ================= Reply-to-update-email (/replyupdateemail) =================
# After a Jenkins build SUCCESS, reply-all in the ORIGINAL update-request email thread
# (mirrored from osedutybot: maintenance.py + maintenance_mail.py). Uses an IMAP+SMTP mailbox
# (Lark Mail by default). MAINTENANCE_MAIL_PASSWORD is REQUIRED for the reply to actually send;
# the rest fall back to the defaults shown below.
MAINTENANCE_MAIL_USER=om@hotelstotsenberg.com
MAINTENANCE_MAIL_PASSWORD=
MAINTENANCE_MAIL_IMAP_HOST=imap.larksuite.com
MAINTENANCE_MAIL_IMAP_PORT=993
MAINTENANCE_MAIL_SMTP_HOST=smtp.larksuite.com
MAINTENANCE_MAIL_SMTP_PORT=465
# Comma-separated Lark mail folders searched (in order) for the original thread.
JENKINS_REPLY_IMAP_FOLDERS=OSE Pending,INBOX,Sent,CLOSED EMAILS
# Lark open_id of the jenkinsbot sender whose /replyupdateemail is accepted without @mention.
JENKINS_BOT_OPEN_ID=
# Chat to post reply status into when a callback / internal POST omits chat_id (optional).
DUTY_CHAT_ID=
# Optional shared secret for POST /internal/reply-update-email (X-Duty-Internal-Token header).
DUTY_INTERNAL_TOKEN=

# ================= Natural-language parser (optional LLM) =================
BOT_CHAT_API_BASE=http://127.0.0.1:11434/v1
BOT_CHAT_API_KEY=ollama
BOT_CHAT_MODEL=qwen3.6:35b-a3b
# BOT_JENKINS_AGENT_DISABLE_LLM=1
